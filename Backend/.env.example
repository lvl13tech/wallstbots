# Wall St. Bots Backend Configuration
# Copy to .env and fill in real values

# ============================================================================
# SUPABASE
# ============================================================================
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=YOUR_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SERVICE_ROLE_KEY
JWT_SECRET=YOUR_JWT_SECRET_FROM_SUPABASE

# Database (use the Connection Pooling URL from Supabase)
DATABASE_URL=postgresql://postgres:PASSWORD@YOUR_PROJECT.supabase.co:6543/postgres

# ============================================================================
# PAYPAL
# ============================================================================
PAYPAL_CLIENT_ID=YOUR_CLIENT_ID
PAYPAL_CLIENT_SECRET=YOUR_CLIENT_SECRET
PAYPAL_MODE=sandbox

# ============================================================================
# EMAIL (SendGrid for password resets)
# ============================================================================
SENDGRID_API_KEY=YOUR_SENDGRID_API_KEY

# ============================================================================
# GCP (Cloud Run deployment)
# ============================================================================
GCP_PROJECT_ID=lvl13-tracker-496402
GCP_REGION=us-east1

# ============================================================================
# ENVIRONMENT
# ============================================================================
ENVIRONMENT=development
DEBUG=true
